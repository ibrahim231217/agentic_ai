# OpenRouter API Key (for Document Agent and Information Agent)
# Get free key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini API Key (for Summarization Agent)
# Get free key at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Your name for OpenRouter requests
OPENROUTER_USERNAME=your_username

# Application settings
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
